# AgentCommons Docker Compose Configuration
# Copy to .env and customize for your deployment

# ===== MCP Memory Server =====

# Port where MCP Memory Server listens
# Default: 8765
# If using remote deployment, ensure this port is accessible
MCP_PORT=8765

# Data persistence: where to mount the Docker volume
# Default: ./_data (relative to docker-compose.yml location)
# Use absolute path for production: /var/lib/agentcommons/data
DATA_MOUNT_PATH=./_data

# Embedding model for semantic search
# Options: nomic-embed-text (default), all-MiniLM-L6-v2, etc.
EMBEDDING_MODEL=nomic-embed-text

# Log level for MCP server
# Options: debug, info (default), warn, error
LOG_LEVEL=info

# ===== Network Configuration =====

# API network name (used by agents to connect)
# Default: agentcommons-network
NETWORK_NAME=agentcommons-network

# ===== Optional: Remote Access =====

# If deployed on a remote server, agents should use:
# AGENTCOMMONS_API_URL=http://<server-ip>:8765

# Expose externally (bind to 0.0.0.0 instead of 127.0.0.1)
# Only set to true if behind firewall or using VPN
EXPOSE_EXTERNAL=false

# ===== Optional: Reverse Proxy (Nginx) =====

# Enable if using Nginx in front of MCP server
ENABLE_NGINX_PROXY=false
NGINX_PORT=80
